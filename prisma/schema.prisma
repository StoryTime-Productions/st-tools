// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ──────────────────────────────────────────────────────────────────────

model User {
  id                     String               @id @default(uuid())
  email                  String               @unique
  name                   String?
  avatarUrl              String?
  role                   Role                 @default(MEMBER)
  primaryColor           String?
  secondaryColor         String?
  foregroundColor        String?
  cardBackgroundColor    String?
  backgroundMode         BackgroundMode       @default(NONE)
  backgroundColor        String?
  backgroundImageUrl     String?
  backgroundImageStyle   BackgroundImageStyle @default(STRETCH)
  backgroundPatternScale Int                  @default(100)
  backgroundImageOpacity Int                  @default(45)
  pomodoroWorkMin        Int                  @default(25)
  pomodoroShortBreakMin  Int                  @default(5)
  pomodoroLongBreakMin   Int                  @default(15)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  // Relations
  boards                       Board[]
  boardMemberships             BoardMember[]
  cards                        Card[]
  cardActivities               CardActivity[]
  pomodoroSessions             PomodoroSession[]
  ownedFocusSessions           PomodoroFocusSession[]        @relation("PomodoroFocusSessionOwner")
  focusSessionMemberships      PomodoroFocusSessionMember[]
  sentFocusSessionRequests     PomodoroFocusSessionRequest[] @relation("PomodoroFocusSessionRequestRequester")
  receivedFocusSessionRequests PomodoroFocusSessionRequest[] @relation("PomodoroFocusSessionRequestTarget")
  minigameLeaderboardEntries   MinigameLeaderboardEntry[]
  pages                        Page[]

  @@map("users")
}

enum Role {
  ADMIN
  MEMBER
}

enum BackgroundMode {
  NONE
  COLOR
  IMAGE
}

enum BackgroundImageStyle {
  STRETCH
  PATTERN
}

enum CardActivityEvent {
  CREATED
  UPDATED
  MOVED
  COMMENTED
}

enum FocusSessionRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

// ─── Kanban ────────────────────────────────────────────────────────────────────

model Board {
  id                String   @id @default(uuid())
  title             String
  description       String?
  isPersonal        Boolean  @default(false)
  isOpenToWorkspace Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  columns        Column[]
  members        BoardMember[]
  cardActivities CardActivity[]

  @@map("boards")
}

model BoardMember {
  id      String @id @default(uuid())
  boardId String
  userId  String

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@map("board_members")
}

model Column {
  id       String @id @default(uuid())
  title    String
  position Int

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]

  @@map("columns")
}

model Card {
  id          String    @id @default(uuid())
  title       String
  description String?
  position    Int
  dueDate     DateTime?
  labels      String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  columnId String
  column   Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  checklistItems CardChecklistItem[]
  activities     CardActivity[]

  @@map("cards")
}

model CardActivity {
  id        String            @id @default(uuid())
  eventType CardActivityEvent
  details   Json?
  createdAt DateTime          @default(now())

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([cardId, createdAt])
  @@index([boardId, createdAt])
  @@map("card_activities")
}

model CardChecklistItem {
  id        String  @id @default(uuid())
  content   String
  completed Boolean @default(false)
  position  Int

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_checklist_items")
}

// ─── Pomodoro & Leaderboard ────────────────────────────────────────────────────

model PomodoroSession {
  id          String   @id @default(uuid())
  durationMin Int
  completedAt DateTime @default(now())
  points      Int      @default(1)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pomodoro_sessions")
}

model PomodoroFocusSession {
  id         String   @id @default(uuid())
  title      String
  isActive   Boolean  @default(true)
  timerState Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ownerId String
  owner   User   @relation("PomodoroFocusSessionOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members  PomodoroFocusSessionMember[]
  requests PomodoroFocusSessionRequest[]

  @@map("pomodoro_focus_sessions")
}

model PomodoroFocusSessionMember {
  id       String    @id @default(uuid())
  isActive Boolean   @default(true)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  sessionId String
  session   PomodoroFocusSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId, isActive])
  @@index([sessionId, isActive])
  @@map("pomodoro_focus_session_members")
}

model PomodoroFocusSessionRequest {
  id          String                    @id @default(uuid())
  status      FocusSessionRequestStatus @default(PENDING)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  respondedAt DateTime?

  sessionId String
  session   PomodoroFocusSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  requesterId String
  requester   User   @relation("PomodoroFocusSessionRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  targetUserId String
  targetUser   User   @relation("PomodoroFocusSessionRequestTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([requesterId, status])
  @@index([targetUserId, status])
  @@map("pomodoro_focus_session_requests")
}

model MinigameLeaderboardEntry {
  id           String   @id @default(uuid())
  gameKey      String
  allTimeScore Int      @default(0)
  bestScore    Int      @default(0)
  plays        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameKey, userId])
  @@index([gameKey, allTimeScore])
  @@map("minigame_leaderboard_entries")
}

// ─── Knowledge Base ────────────────────────────────────────────────────────────

model Page {
  id         String   @id @default(uuid())
  title      String   @default("Untitled")
  content    Json?
  icon       String?
  coverUrl   String?
  isPersonal Boolean  @default(false)
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Page?   @relation("PageChildren", fields: [parentId], references: [id])
  children Page[]  @relation("PageChildren")

  @@map("pages")
}
