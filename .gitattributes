# Normalize line endings to LF on commit, checkout as-is
* text=auto eol=lf

# Force LF for these file types regardless of OS
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf

# Binary — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
