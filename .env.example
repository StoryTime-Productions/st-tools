# ── Local / Development (Supabase CLI) ───────────────────────────────────────
# Start local Supabase with: pnpm supabase:start
# Inspect the running stack with: pnpm supabase:status
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_local_key_from_supabase_status"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_local_key_from_supabase_status"
# Optional Prisma pg driver pool tuning (use low values in Preview/Serverless)
PRISMA_POOL_MAX="1"
PRISMA_POOL_IDLE_TIMEOUT_MS="10000"
PRISMA_POOL_CONNECTION_TIMEOUT_MS="10000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Preview (separate Supabase project) ───────────────────────────────────────
# Store these as GitHub Actions secrets (PREVIEW_DATABASE_URL, PREVIEW_DIRECT_URL).
# In Vercel Preview environment scope, use DATABASE_URL and DIRECT_URL (same names as production)
# plus NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY.
# PREVIEW_DATABASE_URL="postgresql://postgres.yyyy:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# PREVIEW_DIRECT_URL="postgresql://postgres.yyyy:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
